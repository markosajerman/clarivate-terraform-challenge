# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore all .tfvars files except non-sensitive ones
*.tfvars
*.tfvars.json

# Track non-sensitive tfvars
!prod.tfvars
!dev.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Binary plan files
tfplan*.binary
